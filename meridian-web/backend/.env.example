# Database
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-in-production

# Encryption key for API keys in DB (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# File storage paths
UPLOAD_DIR=uploads
TRANSCRIPTION_DIR=transcriptions

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
