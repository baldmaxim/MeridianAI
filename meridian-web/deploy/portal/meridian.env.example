# Пример env для portal-compose (§18). На VPS: meridian.env (НЕ в git), права 600.
# Реальные секреты — из secret storage, не из этого файла.

# Registry и immutable-тег образа (git SHA). Задаются deploy.sh.
REGISTRY=ghcr.io/<owner>
TAG=<git-sha>

# БД — только Yandex Managed PostgreSQL (порт 6432 = pgbouncer, SSL обязателен).
# Локального postgres-контейнера нет. asyncpg-драйвер + statement_cache отключается в коде.
DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>.mdb.yandexcloud.net:6432/Meridian_AI
DATABASE_SSL=true
# Опц.: отдельный URL для миграций (DDL-юзер). Пусто = фолбэк на DATABASE_URL.
MIGRATION_DATABASE_URL=

# App-секреты
JWT_SECRET=<strong-random-secret>
ENCRYPTION_KEY=<fernet-key>

# CORS (prod-домен)
CORS_ORIGINS=https://app.example.com

# Observability (§20) — опционально
SENTRY_DSN=
ENVIRONMENT=production

# Keycloak OIDC (§9/§12). AUTH_MODE: local|keycloak|both (default local = SSO выключен).
# Активировать: AUTH_MODE=both + зарегистрировать confidential client `meridian` в realm your-realm,
# redirect URI = https://app.example.com/api/auth/oidc/callback, client role `admin` (опц.).
AUTH_MODE=local
OIDC_ISSUER=https://auth.example.com/realms/your-realm
OIDC_CLIENT_ID=meridian
OIDC_CLIENT_SECRET=<client-secret>
OIDC_REDIRECT_URI=https://app.example.com/api/auth/oidc/callback
FRONTEND_URL=https://app.example.com

# S3-совместимое хранилище (§15). Браузер грузит batch-аудио напрямую.
# На бакете включить CORS: PUT/GET с origin https://app.example.com.
S3_ENDPOINT=https://s3.example.com
S3_REGION=ru-central-1
S3_BUCKET=<bucket-name>
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
CORS_ORIGINS=["https://app.example.com"]
