# Пример env для portal-compose (§18). На VPS: meridian.env (НЕ в git), права 600.
# Реальные секреты — из secret storage, не из этого файла.

# Registry и immutable-тег образа (git SHA). Задаются deploy.sh.
REGISTRY=ghcr.io/<owner>
TAG=<git-sha>

# Пароли БД (§7): superuser / migration (DDL) / runtime (DML)
DB_PASSWORD=<postgres-superuser-pass>
MIGRATION_DB_PASSWORD=<migration-user-pass>
RUNTIME_DB_PASSWORD=<runtime-user-pass>

# App-секреты
JWT_SECRET=<strong-random-secret>
ENCRYPTION_KEY=<fernet-key>

# CORS (prod-домен)
CORS_ORIGINS=https://meridian.fvds.ru

# Observability (§20) — опционально
SENTRY_DSN=
ENVIRONMENT=production

# S3-совместимое хранилище (§15) — cloud.ru. Браузер грузит batch-аудио напрямую.
# На бакете включить CORS: PUT/GET с origin https://meridian.fvds.ru.
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_BUCKET=<bucket-name>
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
CORS_ORIGINS=["https://meridian.fvds.ru"]
