# Значения деплоя для скриптов deploy/*.sh.
# Скопируйте в `.deploy.env` (gitignored) и заполните реальными значениями,
# либо экспортируйте эти переменные в окружении перед запуском.
#
#   cp .deploy.env.example .deploy.env && nano .deploy.env
#
# Скрипты читают их как ${VAR:-fallback}, поэтому без них используются нейтральные заглушки.

# GHCR-владелец образов (ghcr.io/<OWNER>/meridian-*)
OWNER=your-org

# Публичный домен портала
DOMAIN=app.example.com

# SSH-алиас/host прод-сервера (см. ~/.ssh/config)
DEPLOY_SSH=your-server

# Каталог портала на сервере
REMOTE_DIR=/opt/portals/app

# Каталог infra-nginx на сервере
INFRA_DIR=/opt/infra/nginx
